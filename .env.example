# ─────────────────────────────────────────────────────────────────────────────
# proxmox-admin — local environment variables
# Copy this file to .env and fill in the values for your setup.
#   cp .env.example .env
# .env is gitignored; never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────


# ── Proxmox server ────────────────────────────────────────────────────────────
# IP address or hostname of your Proxmox VE node.
PROXMOX_HOST=192.168.1.10

# API port (default 8006).
PROXMOX_PORT=8006

# Login username (without realm).
PROXMOX_USER=root

# Login password.
PROXMOX_PASS=changeme

# Realm: pam (Linux PAM), pve (Proxmox auth), or an LDAP realm name.
PROXMOX_REALM=pam

# Set to "true" only if your Proxmox cert is trusted (not self-signed).
# Leave "false" for homelabs with the default self-signed certificate.
PROXMOX_TLS_REJECT_UNAUTHORIZED=false


# ── Polling worker ────────────────────────────────────────────────────────────
# How often the worker polls Proxmox, in milliseconds.
POLL_INTERVAL_MS=15000

# Worker log verbosity: debug | info | warn | error
LOG_LEVEL=info


# ── Redis ─────────────────────────────────────────────────────────────────────
# Used by both the worker (publishes events) and the API (subscribes + SSE).
# When running via docker compose, use the service name: redis://redis:6379
# When running the worker locally against a docker redis: redis://localhost:6379
REDIS_URL=redis://localhost:6379


# ── API (NestJS BFF) ──────────────────────────────────────────────────────────
# PostgreSQL connection string.
# docker compose local:   postgresql://proxmox_admin:proxmox_admin@localhost:5432/proxmox_admin
# inside docker network:  postgresql://proxmox_admin:proxmox_admin@postgres:5432/proxmox_admin
DATABASE_URL=postgresql://proxmox_admin:proxmox_admin@localhost:5432/proxmox_admin

# Port the API listens on.
PORT=3000

# Allowed CORS origin for the web frontend.
# Comma-separated when running both direct (port 5173) and via Caddy (https://localhost).
CORS_ORIGIN=http://localhost:5173,https://localhost

# App environment.
NODE_ENV=development
