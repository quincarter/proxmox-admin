{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/**/*.e2e-spec.ts",
      "!{projectRoot}/jest.config.*",
      "!{projectRoot}/vitest.config.*"
    ],
    "sharedGlobals": []
  },
  "targetDefaults": {
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "continuous": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "test": {
      "inputs": ["default", "^production"],
      "cache": true
    },
    "lint": {
      "inputs": ["default"],
      "cache": true
    },
    "verify": {
      "dependsOn": ["lint", "build", "test"],
      "inputs": ["default", "^production"],
      "cache": true
    }
  },
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "packages"
  }
}
