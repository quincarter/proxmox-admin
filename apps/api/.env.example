# Proxmox Admin BFF — environment variables
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL connection string
# For local dev, start the database with: docker compose up postgres -d
DATABASE_URL="postgresql://proxmox_admin:proxmox_admin@localhost:5432/proxmox_admin"

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# Optional: comma-separated host:port hints for discovery
# PROXMOX_HINTS=192.168.1.10:8006,192.168.1.11:8006
